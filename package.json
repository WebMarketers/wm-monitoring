{
  "name": "webmarketers-monitoring",
  "version": "1.0.0",
  "description": "Webmarketers Monitoring Dashboard",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "deploy": "bash scripts/deploy.sh",
    "deploy:watch": "nodemon --watch . --ext js,html,css,json --ignore 'node_modules/*' --ignore 'clients/*' --ignore '*.db' --ignore 'scripts/*' --ignore '.git/*' --exec 'bash scripts/deploy.sh' --delay 2"
  },
  "dependencies": {
    "@aws-sdk/client-ses": "^3.1021.0",
    "axios": "^1.6.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.4",
    "express": "^4.18.2",
    "knex": "^3.1.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.4",
    "sqlite3": "^5.1.7",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3"
  }
}
